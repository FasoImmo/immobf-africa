# =====================================================================
# ImmoBF Africa - FRONTEND-WEB production env
# Sur Vercel : Project -> Settings -> Environment Variables
# Toutes les variables NEXT_PUBLIC_* sont exposées au navigateur.
# =====================================================================

# URL publique de l'API backend (Railway)
NEXT_PUBLIC_API_URL=https://api.immobf.africa

# Site URL (utilisé pour les meta OG, partage social, sitemap)
NEXT_PUBLIC_SITE_URL=https://immobf.africa

# Locale par défaut
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Map / Leaflet tiles (OpenStreetMap par défaut)
NEXT_PUBLIC_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Analytics (optionnel - Plausible auto-hébergé recommandé)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=immobf.africa
NEXT_PUBLIC_PLAUSIBLE_API=https://plausible.io

# Sentry (optionnel - error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# Build flags
NODE_ENV=production
