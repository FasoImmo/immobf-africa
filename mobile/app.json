{
  "expo": {
    "name": "ImmoBF Africa",
    "slug": "immobilier-en-afrique",
    "owner": "immobfs-team",
    "version": "1.4.0",
    "orientation": "portrait",
    "scheme": "immobf",
    "primaryColor": "#0E7C66",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E7C66"
    },
    "updates": { "fallbackToCacheTimeout": 0 },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "africa.immobf.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ImmoBF utilise votre position pour géolocaliser votre annonce sur la carte."
      }
    },
    "android": {
      "package": "africa.immobf.app",
      "versionCode": 4,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "extra": {
      "apiUrl": "https://immobf-africa-production.up.railway.app",
      "eas": {
        "projectId": "bc9af3b2-4772-4b18-b0e2-96cdb8751222"
      }
    }
  }
}
