{
  "expo": {
    "name": "ImmoBF Africa",
    "slug": "immobf-africa",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "immobf",
    "primaryColor": "#0E7C66",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E7C66"
    },
    "updates": { "fallbackToCacheTimeout": 0 },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "africa.immobf.app" },
    "android": { "package": "africa.immobf.app", "versionCode": 1 },
    "web": { "favicon": "./assets/favicon.png" }
  }
}
