# =====================================================================
# ImmoBF Africa - BACKEND production env
# Copie ce fichier en .env.production puis renseigne chaque valeur.
# Sur Railway, charge ces variables via Project -> Variables (UI) ou
#    railway variables set KEY=VALUE
# =====================================================================

# --- Runtime ---
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# --- Database (Railway Postgres plugin fournit automatiquement DATABASE_URL) ---
# Format attendu: postgres://USER:PASS@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# --- Redis (Railway Redis plugin fournit REDIS_URL) ---
REDIS_URL=

# --- MongoDB (transaction log 10 ans BCEAO) - utilise MongoDB Atlas Free M0 ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/immobf?retryWrites=true&w=majority

# --- Auth ---
# Génère 64 caractères aléatoires : openssl rand -hex 32
JWT_SECRET=__CHANGE_ME_64_HEX_CHARS__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- CORS ---
# Domaines autorisés à appeler l'API (séparés par virgules)
CORS_ORIGINS=https://immobf.africa,https://www.immobf.africa

# --- URLs publiques ---
PUBLIC_API_URL=https://api.immobf.africa
PUBLIC_WEB_URL=https://immobf.africa

# =====================================================================
# FEDAPAY — agrégateur PRINCIPAL (recommandé)
# Dashboard : https://live.fedapay.com  (sandbox : https://sandbox.fedapay.com)
# Couvre : Orange Money, Moov, MTN, Wave, Visa/Mastercard
# Pays : BF, BJ, CI, SN, TG, NE, ML, GN
# =====================================================================
# Tant que le compte est en cours d'activation, garder FEDAPAY_LIVE=false
# et utiliser les clés sk_test_… / pk_test_… (sandbox).
# Une fois le compte validé, basculer FEDAPAY_LIVE=true et coller les sk_live_…
FEDAPAY_LIVE=false
FEDAPAY_PUBLIC_KEY=pk_sandbox_xxxxxxxxxxxxxxxxxxxxxxxx
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxxxxxxxxxx
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_NOTIFY_URL=https://api.immobf.africa/api/v1/payments/webhooks/fedapay
FEDAPAY_RETURN_URL=https://immobf.africa/payment/return

# =====================================================================
# CINETPAY (agrégateur secondaire optionnel — laisser vide si vous
# concentrez tout sur FedaPay au démarrage)
# Dashboard : https://app.cinetpay.com
# =====================================================================
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_NOTIFY_URL=https://api.immobf.africa/api/v1/payments/webhooks/cinetpay
CINETPAY_RETURN_URL=https://immobf.africa/payment/return

# =====================================================================
# ORANGE MONEY BURKINA FASO (contrat marchand direct)
# Documentation : https://developer.orange.com/apis/om-webpay
# Le webhook signe en HMAC-SHA256 le body avec OM_WEBHOOK_SECRET
# =====================================================================
OM_MERCHANT_KEY=
OM_CLIENT_ID=
OM_CLIENT_SECRET=
OM_WEBHOOK_SECRET=
OM_NOTIFY_URL=https://api.immobf.africa/api/v1/payments/webhooks/orange-money
OM_RETURN_URL=https://immobf.africa/payment/return
OM_USSD_CODE=*144*4*6#

# =====================================================================
# MOOV MONEY BURKINA FASO (contrat marchand direct)
# Le webhook signe en HMAC-SHA256
# =====================================================================
MOOV_MERCHANT_ID=
MOOV_API_KEY=
MOOV_API_SECRET=
MOOV_WEBHOOK_SECRET=
MOOV_NOTIFY_URL=https://api.immobf.africa/api/v1/payments/webhooks/moov-money
MOOV_RETURN_URL=https://immobf.africa/payment/return
MOOV_USSD_CODE=*555*6#

# =====================================================================
# WAVE (contrat marchand direct - https://business.wave.com)
# Doc API : https://docs.wave.com
# =====================================================================
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
WAVE_NOTIFY_URL=https://api.immobf.africa/api/v1/payments/webhooks/wave
WAVE_RETURN_URL=https://immobf.africa/payment/return

# =====================================================================
# Modération IA (optionnel — laisser vide pour heuristiques uniquement)
# =====================================================================
OPENAI_API_KEY=

# =====================================================================
# Stockage photos (optionnel — local par défaut, S3/Backblaze recommandé)
# =====================================================================
S3_ENDPOINT=
S3_BUCKET=immobf-photos
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-west-3

# =====================================================================
# SMS / Email (optionnel)
# =====================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@immobf.africa

# Orange SMS BF (optionnel)
ORANGE_SMS_AUTH=

# --- Migration / seed au premier déploiement seulement ---
SEED_ON_START=false
