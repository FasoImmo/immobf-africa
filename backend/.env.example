# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
APP_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# CORS — liste des origines autorisées (séparées par des virgules, sans espaces)
# En production : CORS_ORIGINS=https://www.immoafrica.online,https://immoafrica.online
CORS_ORIGINS=http://localhost:3000

# Databases
DATABASE_URL=postgres://immobf:immobf_dev@localhost:5432/immobf
REDIS_URL=redis://localhost:6379
MONGO_URL=mongodb://immobf:immobf_dev@localhost:27017/immobf?authSource=admin

# Auth
JWT_SECRET=replace_with_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Mobile Money — CinetPay (multi-opérateurs Burkina)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_NOTIFY_URL=http://localhost:4000/api/v1/payments/webhooks/cinetpay

# Orange Money Burkina
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_AUTH_HEADER=
ORANGE_MONEY_WEBHOOK_SECRET=
ORANGE_MONEY_NOTIFY_URL=http://localhost:4000/api/v1/payments/webhooks/orange_money

# Moov Money Burkina
MOOV_MONEY_USERNAME=
MOOV_MONEY_PASSWORD=
MOOV_MONEY_WEBHOOK_SECRET=

# Wave
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# SMS (OTP) — Twilio fallback + Orange SMS API recommandé en prod
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@immobf.africa

# Storage (photos, PDF)
STORAGE_DRIVER=local          # local | s3
STORAGE_LOCAL_DIR=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Meta Lead Ads webhook (contacts CRM automatique)
# META_VERIFY_TOKEN : token libre, doit correspondre à celui saisi dans Meta for Developers
# META_APP_SECRET   : App Secret → Meta for Developers > Settings > Basic
# META_PAGE_ACCESS_TOKEN : token de page avec permission leads_retrieval
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# Traduction automatique (EN ↔ FR) — DeepL Free API
# Créer un compte sur https://www.deepl.com/pro-api (plan Free = 500 000 car/mois)
# La clé se termine par ":fx" pour le plan gratuit, ex: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx
DEEPL_API_KEY=

# Commissions & frais
APP_COMMISSION_PCT=2          # % prélevé sur les transactions
BOOST_PRICE_XOF=5000          # prix du boost d'une annonce
AGENCY_SUBSCRIPTION_XOF=20000 # abonnement mensuel agences
