{
  "name": "immobf-africa-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API backend ImmoBF Africa — immobilier + mobile money Burkina Faso",
  "license": "MIT",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/utils/migrate.js up && node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/utils/migrate.js up",
    "migrate:down": "node src/utils/migrate.js down",
    "seed": "node src/utils/seed.js",
    "lint": "eslint src tests --ext .js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.5.0",
    "cloudinary": "^2.3.1",
    "resend": "^3.2.0",
    "node-cron": "^3.0.3",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.5",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/"]
  }
}
